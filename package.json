{
  "name": "vscode-touch-bar",
  "displayName": "Touch Bar",
  "version": "0.0.15",
  "description": "Touchbar Setting",
  "main": "./out/extension.js",
  "icon": "doc-images/icon.png",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pack": "vsce package",
    "publish": "vsce publish"
  },
  "author": "Avni Onur Pehlivan @Augustpi",
  "publisher": "AvniOnurPehlivan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Elcaten/touch_bar"
  },
  "bugs": {
    "url": "https://github.com/Elcaten/touch_bar/issues"
  },
  "homepage": "https://github.com/Elcaten/touch_bar",
  "engines": {
    "vscode": "^1.74.0"
  },
  "activationEvents": [],
  "categories": [
    "Other"
  ],
  "keywords": [
    "macbook pro",
    "touchbar",
    "extra buttons",
    "shortcuts",
    "vscode",
    "visual studio code",
    "macbook",
    "developers",
    "touch bar"
  ],
  "contributes": {
    "commands": [
      {
        "command": "touchbar.editor.action.revealDefinition",
        "title": "→ƒ"
      },
      {
        "command": "touchbar.editor.action.goToReferences",
        "title": "→🔗"
      },
      {
        "command": "touchbar.workbench.action.terminal.toggleTerminal",
        "title": "⬓"
      },
      {
        "command": "touchbar.workbench.action.showCommands",
        "title": ">_"
      },
      {
        "command": "touchbar.editor.action.blockComment",
        "title": "/* */"
      },
      {
        "command": "touchbar.editor.action.rename",
        "title": "🖊"
      },
      {
        "command": "touchbar.editor.action.refactor",
        "title": "💡"
      },
      {
        "command": "touchbar.workbench.action.toggleSidebarVisibility",
        "title": "◧"
      },
      {
        "command": "touchbar.editor.action.copyLinesDownAction",
        "title": "☰↓"
      },
      {
        "command": "touchbar.workbench.action.terminal.focusNextPane",
        "title": "←◧→"
      },
      {
        "command": "touchbar.workbench.action.splitEditor",
        "title": "↝◧"
      },
      {
        "command": "touchbar.editor.action.jumpToBracket",
        "title": "→}"
      },
      {
        "command": "touchbar.workbench.action.closePanel",
        "title": "Close"
      },
      {
        "command": "touchbar.workbench.action.toggleMaximizedPanel",
        "title": "Max–Min"
      }
    ],
    "menus": {
      "touchBar": [
        {
          "command": "touchbar.editor.action.revealDefinition",
          "when": "editorFocus"
        },
        {
          "command": "touchbar.editor.action.goToReferences",
          "when": "editorFocus"
        },
        {
          "command": "touchbar.workbench.action.terminal.toggleTerminal",
          "when": "editorFocus"
        },
        {
          "command": "touchbar.workbench.action.showCommands",
          "when": "editorFocus"
        },
        {
          "command": "touchbar.editor.action.blockComment",
          "when": "editorHasMultipleSelections"
        },
        {
          "command": "touchbar.editor.action.rename",
          "when": "editorFocus"
        },
        {
          "command": "touchbar.editor.action.refactor",
          "when": "editorFocus"
        },
        {
          "command": "touchbar.editor.action.blockComment",
          "when": "editorHasSelection && !editorHasMultipleSelections"
        },
        {
          "command": "touchbar.workbench.action.toggleSidebarVisibility",
          "when": "editorFocus"
        },
        {
          "command": "touchbar.workbench.action.toggleSidebarVisibility",
          "when": "terminalFocus"
        },
        {
          "command": "touchbar.editor.action.copyLinesDownAction",
          "when": "editorFocus"
        },
        {
          "command": "touchbar.workbench.action.terminal.focusNextPane",
          "when": "terminalFocus"
        },
        {
          "command": "touchbar.workbench.action.splitEditor",
          "when": "editorFocus"
        },
        {
          "command": "touchbar.editor.action.jumpToBracket",
          "when": "editorFocus"
        },
        {
          "command": "touchbar.workbench.action.closePanel",
          "when": "terminalFocus"
        },
        {
          "command": "touchbar.workbench.action.toggleMaximizedPanel",
          "when": "terminalFocus"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
